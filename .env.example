# ── GitHub ──────────────────────────────────────
GITHUB_USERNAME=ridhwanrazaliwork
GITHUB_TOKEN=

# ── LLM (via LiteLLM → OpenRouter) ─────────────
# All models use OpenRouter as the provider.
# LITELLM_API_KEY = your OpenRouter API key (one key for both)
#
# Chat model
LITELLM_MODEL=openrouter/google/gemini-2.5-flash-lite
# Embedding model
LITELLM_EMBEDDING_MODEL=openrouter/qwen3-embedding-8b
LITELLM_API_KEY=

# ── Storage ─────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Debug ───────────────────────────────────────
LITELLM_DEBUG=false

# ── CORS ────────────────────────────────────────
# Comma-separated origins allowed to call this API from a browser.
# Dev:   CORS_ORIGINS=*
# Prod:  CORS_ORIGINS=https://ridhwanrazali.dev,http://localhost:3000
CORS_ORIGINS=*

# ── Production (Render) ─────────────────────────
# For Render persistent disk, set: CHROMA_DB_PATH=/data/chroma_db
